{
  "name": "modpack-installer",
  "version": "1.0.5",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "StormGamesStudios",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@fluentui/react": "^8.125.5",
    "@fluentui/react-components": "^9.73.5",
    "@fluentui/web-components": "^2.6.1",
    "@material/web": "^2.4.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.14.0",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.4"
  },
  "build": {
    "appId": "com.stormgamesstudios.modpackinstaller",
    "artifactName": "Modpack-Installer-Setup-${version}.${ext}",
    "productName": "Modpack Installer",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "installers",
      "minecraftlauncher",
      "compatibility",
      "node_modules",
      "renderer",
      "instances.json",
      "main.js",
      "preload.js",
      "package.json",
      "config.json",
      "assets"
    ],
    "asarUnpack": [
      "minecraftlauncher/**",
      "compatibility/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "acierto-incomodo",
        "repo": "modpack-installer"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/logo.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Modpack Installer",
      "differentialPackage": true
    }
  }
}
