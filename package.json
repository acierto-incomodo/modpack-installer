{
  "name": "modpack-installer",
  "version": "1.0.2",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "StormGamesStudios",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@fluentui/react": "^8.125.5",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.3"
  },
  "build": {
    "appId": "com.stormgamesstudios.modpackinstaller",
    "artifactName": "Modpack-Installer-Setup-${version}.${ext}",
    "productName": "Modpack Installer",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "**/*"
    ],
    "asarUnpack": [
      "minecraftlauncher/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "acierto-incomodo",
        "repo": "modpack-installer"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Modpack Installer"
    }
  }
}
